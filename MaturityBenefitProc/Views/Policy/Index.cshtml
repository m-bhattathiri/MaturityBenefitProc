@model IEnumerable<MaturityBenefitProc.Models.Policy>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Maturing Policies";
}

<div class="row" style="margin-top: 10px;">
    <div class="col-md-8">
        <h2>Maturing Policies</h2>
        <p class="text-muted">Policies approaching or past maturity date, awaiting benefit processing.</p>
    </div>
    <div class="col-md-4 text-right" style="margin-top: 20px;">
        <form action="@Url.Action("Search", "Policy")" method="get" class="form-inline">
            <div class="input-group">
                <input type="text" class="form-control" name="query" placeholder="Policy No. / CIF / Name..." />
                <span class="input-group-btn">
                    <button class="btn btn-primary" type="submit">
                        <span class="glyphicon glyphicon-search"></span> Search
                    </button>
                </span>
            </div>
        </form>
    </div>
</div>

<div class="row" style="margin-top: 10px;">
    <div class="col-md-12">
        <div class="btn-group" role="group">
            <a href="@Url.Action("Index", "Policy", new { status = "all" })" class="btn btn-default @(ViewBag.FilterStatus == "all" ? "active" : "")">All</a>
            <a href="@Url.Action("Index", "Policy", new { status = "maturing" })" class="btn btn-default @(ViewBag.FilterStatus == "maturing" ? "active" : "")">Maturing Soon</a>
            <a href="@Url.Action("Index", "Policy", new { status = "matured" })" class="btn btn-default @(ViewBag.FilterStatus == "matured" ? "active" : "")">Matured</a>
            <a href="@Url.Action("Index", "Policy", new { status = "claimed" })" class="btn btn-default @(ViewBag.FilterStatus == "claimed" ? "active" : "")">Claim Filed</a>
            <a href="@Url.Action("Index", "Policy", new { status = "disbursed" })" class="btn btn-default @(ViewBag.FilterStatus == "disbursed" ? "active" : "")">Disbursed</a>
        </div>
    </div>
</div>

<div class="row" style="margin-top: 15px;">
    <div class="col-md-12">
        <div class="panel panel-default">
            <div class="panel-heading">
                <strong>Policy Listing</strong>
                <span class="badge pull-right">@ViewBag.TotalCount records</span>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered">
                    <thead style="background-color: #1a5276; color: white;">
                        <tr>
                            <th><a href="#" style="color: white;">Policy Number</a></th>
                            <th>Policyholder</th>
                            <th>Type</th>
                            <th class="text-right">Sum Assured</th>
                            <th>Maturity Date</th>
                            <th>Status</th>
                            <th>Branch</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var policy in Model)
                            {
                                <tr>
                                    <td><a href="@Url.Action("Details", "Policy", new { policyNumber = policy.PolicyNumber })"><strong>@policy.PolicyNumber</strong></a></td>
                                    <td>@(policy.Policyholder != null ? policy.Policyholder.FullName : "N/A")</td>
                                    <td><span class="label label-info">@policy.PolicyType</span></td>
                                    <td class="text-right">@String.Format("{0:N0}", policy.SumAssured)</td>
                                    <td>@policy.MaturityDate.ToString("dd-MMM-yyyy")</td>
                                    <td>
                                        @switch (policy.PolicyStatus)
                                        {
                                            case MaturityBenefitProc.Models.PolicyStatus.Matured:
                                                <span class="label label-success">Matured</span>
                                                break;
                                            case MaturityBenefitProc.Models.PolicyStatus.Active:
                                                <span class="label label-primary">Active</span>
                                                break;
                                            case MaturityBenefitProc.Models.PolicyStatus.Lapsed:
                                                <span class="label label-danger">Lapsed</span>
                                                break;
                                            default:
                                                <span class="label label-default">@policy.PolicyStatus</span>
                                                break;
                                        }
                                    </td>
                                    <td>@policy.BranchCode</td>
                                    <td>
                                        <a href="@Url.Action("Details", "Policy", new { policyNumber = policy.PolicyNumber })" class="btn btn-xs btn-info" title="View Details">
                                            <span class="glyphicon glyphicon-eye-open"></span>
                                        </a>
                                        <a href="@Url.Action("Create", "Claim", new { policyNumber = policy.PolicyNumber })" class="btn btn-xs btn-success" title="Initiate Claim">
                                            <span class="glyphicon glyphicon-plus"></span>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted" style="padding: 30px;">
                                    <span class="glyphicon glyphicon-info-sign"></span>
                                    No policies found matching the current filter criteria.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <p class="text-muted">Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages</p>
    </div>
    <div class="col-md-6 text-right">
        <nav>
            <ul class="pagination pagination-sm">
                <li class="disabled"><a href="#">&laquo; Prev</a></li>
                <li class="active"><a href="#">1</a></li>
                <li><a href="#">Next &raquo;</a></li>
            </ul>
        </nav>
    </div>
</div>
