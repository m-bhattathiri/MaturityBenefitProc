@model System.Web.Mvc.HandleErrorInfo
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Error";
}

<div class="row" style="margin-top: 30px;">
    <div class="col-md-8 col-md-offset-2">
        <div class="panel panel-danger">
            <div class="panel-heading">
                <h3 class="panel-title">An Error Occurred</h3>
            </div>
            <div class="panel-body">
                <div class="text-center" style="padding: 20px 0;">
                    <span class="glyphicon glyphicon-exclamation-sign" style="font-size: 48px; color: #c0392b;"></span>
                </div>
                <h4 class="text-center">Something went wrong while processing your request.</h4>
                <p class="text-center text-muted">
                    The maturity benefit processing system encountered an unexpected error.
                    Please try again or contact the support team if the issue persists.
                </p>

                @if (Model != null)
                {
                    <div class="well well-sm" style="margin-top: 20px;">
                        <dl class="dl-horizontal">
                            <dt>Controller:</dt>
                            <dd>@Model.ControllerName</dd>
                            <dt>Action:</dt>
                            <dd>@Model.ActionName</dd>
                            <dt>Error Type:</dt>
                            <dd>@Model.Exception.GetType().Name</dd>
                        </dl>
                    </div>
                }

                <div class="text-center" style="margin-top: 20px;">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">
                        <span class="glyphicon glyphicon-home"></span> Return to Dashboard
                    </a>
                    <a href="@Url.Action("Contact", "Home")" class="btn btn-default btn-lg" style="margin-left: 10px;">
                        <span class="glyphicon glyphicon-envelope"></span> Contact Support
                    </a>
                </div>

                <div class="text-center text-muted" style="margin-top: 30px; font-size: 12px;">
                    <p>Error Reference: @DateTime.UtcNow.ToString("yyyyMMddHHmmss") | Please quote this reference when contacting support.</p>
                </div>
            </div>
        </div>
    </div>
</div>
