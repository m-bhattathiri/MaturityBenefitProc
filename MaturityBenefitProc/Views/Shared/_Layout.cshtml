<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MaturityBenefitProc</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>
        .navbar-brand-logo { font-weight: bold; color: #1a5276 !important; }
        .insurance-header { background-color: #1a5276; }
        .footer-bar { background-color: #2c3e50; color: #ecf0f1; padding: 12px 0; margin-top: 40px; font-size: 13px; }
        .footer-bar a { color: #85c1e9; }
        .alert-dismissible { margin-top: 10px; }
        .nav-pills > li > a { color: #1a5276; }
        body { padding-top: 50px; }
    </style>
</head>
<body>
    <div class="navbar navbar-inverse navbar-fixed-top insurance-header">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <a class="navbar-brand navbar-brand-logo" href="@Url.Action("Index", "Home")">
                    MaturityBenefitProc
                </a>
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav">
                    <li>@Html.ActionLink("Home", "Index", "Home")</li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">
                            Policies <span class="caret"></span>
                        </a>
                        <ul class="dropdown-menu">
                            <li>@Html.ActionLink("All Maturing Policies", "Index", "Policy")</li>
                            <li>@Html.ActionLink("Maturity Schedule", "MaturitySchedule", "Policy")</li>
                            <li>@Html.ActionLink("Search Policy", "Search", "Policy")</li>
                        </ul>
                    </li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">
                            Claims <span class="caret"></span>
                        </a>
                        <ul class="dropdown-menu">
                            <li>@Html.ActionLink("All Claims", "Index", "Claim")</li>
                            <li>@Html.ActionLink("Initiate Claim", "Create", "Claim")</li>
                        </ul>
                    </li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">
                            Disbursements <span class="caret"></span>
                        </a>
                        <ul class="dropdown-menu">
                            <li>@Html.ActionLink("All Disbursements", "Index", "Disbursement")</li>
                            <li>@Html.ActionLink("Track Payment", "Track", "Disbursement")</li>
                            <li>@Html.ActionLink("Cheque Status", "ChequeStatus", "Disbursement")</li>
                        </ul>
                    </li>
                    <li>@Html.ActionLink("Reports", "Index", "Report")</li>
                    <li>@Html.ActionLink("Admin", "Index", "Admin")</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="container body-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                @TempData["ErrorMessage"]
            </div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                @TempData["WarningMessage"]
            </div>
        }

        @RenderBody()

        <hr />
        <div class="footer-bar">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <p>MaturityBenefitProc v1.0 &mdash; Life Insurance Maturity Benefit Processing System</p>
                    </div>
                    <div class="col-md-6 text-right">
                        <p>&copy; @DateTime.UtcNow.Year - Operations Division | <a href="@Url.Action("Contact", "Home")">Support</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
